@model List<TravelAgency.Models.Trip>

<h1>Trips</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Trip</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Tour Title</th>
            <th>Price</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var trip in Model)
        {
            <tr>
                <td>@trip.Title</td>
                <td>@trip.Price.ToString("N2")</td>
                <td>@trip.status</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@trip.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Details" asp-route-id="@trip.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@trip.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>