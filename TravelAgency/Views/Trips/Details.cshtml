@model TravelAgency.Models.Trip

<h1>Trip Details</h1>

<div>
    <p><strong>Title:</strong> @Model.Title</p>
    <p><strong>Country:</strong> @Model.Country</p>
    <p><strong>City:</strong> @Model.City</p>
    <p><strong>Hotel Name:</strong> @Model.HotelName</p>
    <p><strong>Hotel Address:</strong> @Model.HotelAddress</p>
    <p><strong>Type Of Holiday:</strong> @Model.typeOfHoliday?.Name</p>
    <p><strong>Number Of Nights:</strong> @Model.NumberOfNights</p>
    <p><strong>Price:</strong> @Model.Price</p>
    <p><strong>Quantity:</strong> @Model.Quantity</p>
    <p><strong>Date:</strong> @Model.date.ToString("yyyy-MM-dd")</p>
    <p><strong>Status:</strong> @Model.status</p>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
