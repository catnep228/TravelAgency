@model TravelAgency.Models.Trip
@using TravelAgency.Models

<h1>Create Trip</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label>Title</label>
        <input asp-for="Title" class="form-control" required />
    </div>
    <div class="mb-3">
        <label>Country</label>
        <input asp-for="Country" class="form-control" required />
    </div>
    <div class="mb-3">
        <label>City</label>
        <input asp-for="City" class="form-control" required />
    </div>
    <div class="mb-3">
        <label>Hotel Name</label>
        <input asp-for="HotelName" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Hotel Address</label>
        <input asp-for="HotelAddress" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Type Of Holiday</label>
        <select asp-for="typeofHoldayId" class="form-control" asp-items="@(new SelectList(ViewBag.TypeOfHolidays, "Id", "Name"))"></select>
    </div>
    <div class="mb-3">
        <label>Number Of Nights</label>
        <input asp-for="NumberOfNights" type="number" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Price</label>
        <input asp-for="Price" type="number" step="0.01" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Quantity</label>
        <input asp-for="Quantity" type="number" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Date</label>
        <input asp-for="date" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Status</label>
        <select asp-for="status" class="form-control">
            @foreach (var s in Enum.GetValues(typeof(StatusTrip)))
            {
                <option value="@s">@s</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
