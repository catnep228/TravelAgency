@model TravelAgency.Models.Order

<h1>Delete Order</h1>

<div class="alert alert-danger">
    Are you sure you want to delete order #@Model.Id?
</div>

<div class="mb-3">
    <p><strong>Date:</strong> @Model.Date.ToShortDateString()</p>
    <p><strong>Trip:</strong> @Model.Trip?.Title</p>
    <p><strong>Passengers Count:</strong> @Model.Passangers.Count</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>