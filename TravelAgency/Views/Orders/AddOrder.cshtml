@model TravelAgency.Models.Order

<h1>Create Order</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<form asp-action="AddOrder" method="post">
    <div class="mb-3">
        <label asp-for="Date" class="form-label">Order Date</label>
        <input asp-for="Date" type="date" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
        <span asp-validation-for="Date" class="text-danger"></span>
    </div>

    <input type="hidden" asp-for="Status" value="@TravelAgency.Models.StatusOrder.Active" />

    <div class="mb-3">
        <label asp-for="TripId" class="form-label">Selected Trip</label>
        <select asp-for="TripId" class="form-select"
                asp-items="@(new SelectList(ViewBag.Trips, "Id", "Title"))" required>
            <option value="">-- Select Trip --</option>
        </select>
        <span asp-validation-for="TripId" class="text-danger"></span>
    </div>

    <hr />
    <h4>Passengers</h4>
    <div id="passengers-container">
    </div>
    <button type="button" class="btn btn-outline-success mb-3" onclick="addPassenger()">+ Add Passenger</button>

    <hr />
    <div class="mb-3">
        <label class="form-label">Additional Services</label>
        <select name="selectedServices" class="form-select" multiple size="5">
            @foreach (var s in ViewBag.Services)
            {
                <option value="@s.Id">@s.Name (@s.Price.ToString("N0") ₽)</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Create Order</button>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Main Page</a>
</form>

@section Scripts {
    <script>
        let pIndex = 0;
        function addPassenger() {
            const container = document.getElementById('passengers-container');
            const html = `
                <div class="passenger-block border p-3 mb-3 bg-light rounded">
                    <div class="d-flex justify-content-between mb-2">
                        <h6>Passenger #${pIndex + 1}</h6>
                        <button type="button" class="btn btn-sm btn-danger" onclick="this.closest('.passenger-block').remove()">Remove</button>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-4"><input name="Passangers[${pIndex}].LastName" class="form-control" placeholder="Last Name" required /></div>
                        <div class="col-md-4"><input name="Passangers[${pIndex}].FirstName" class="form-control" placeholder="First Name" required /></div>
                        <div class="col-md-4"><input name="Passangers[${pIndex}].MiddleName" class="form-control" placeholder="Middle Name" /></div>
                        <div class="col-md-4"><input name="Passangers[${pIndex}].Passport" class="form-control" placeholder="Passport (RU)" /></div>
                        <div class="col-md-4"><input name="Passangers[${pIndex}].InternationalPassport" class="form-control" placeholder="Int. Passport" /></div>
                        <div class="col-md-4"><input name="Passangers[${pIndex}].Policy" class="form-control" placeholder="Insurance Policy" /></div>
                        <div class="col-12 mt-2">
                            <div class="form-check">
                                <input name="Passangers[${pIndex}].BirthCertificate" type="checkbox" class="form-check-input" value="true" id="bc_${pIndex}" />
                                <label class="form-check-label" for="bc_${pIndex}">Birth Certificate (for kids)</label>
                            </div>
                        </div>
                    </div>
                </div>`;
            container.insertAdjacentHTML('beforeend', html);
            pIndex++;
        }
        document.addEventListener('DOMContentLoaded', () => addPassenger());
    </script>
}