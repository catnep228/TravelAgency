@model TravelAgency.Models.Order

<h1>Order Details</h1>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Order #@Model.Id</h5>
        <p class="card-text"><strong>Date:</strong> @Model.Date.ToLongDateString()</p>
        <p class="card-text"><strong>Trip:</strong> @Model.Trip?.Title (@Model.Trip?.City)</p>
        <p class="card-text"><strong>Status:</strong> @Model.Status</p>
    </div>
</div>

<h3>Passengers</h3>
<ul class="list-group mb-3">
    @foreach (var p in Model.Passangers)
    {
        <li class="list-group-item">@p.LastName @p.FirstName (@p.Passport)</li>
    }
</ul>

<h3>Services</h3>
<ul class="list-group mb-3">
    @foreach (var s in Model.AdditionalServices)
    {
        <li class="list-group-item d-flex justify-content-between">
            <span>@s.Name</span>
            <span>@s.Price.ToString("N2") ₽</span>
        </li>
    }
</ul>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Main Page</a>