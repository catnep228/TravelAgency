@model List<TravelAgency.Models.Order>

<h1>Orders</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Order</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Date</th>
            <th>Trip (Title)</th>
            <th>Passengers</th>
            <th>Services</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>@o.Id</td>
                <td>@o.Date.ToShortDateString()</td>
                <td>@(o.Trip?.Title ?? "N/A")</td>
                <td>@(o.Passangers?.Count ?? 0)</td>
                <td>@(o.AdditionalServices?.Count ?? 0)</td>
                <td>@o.Status</td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@o.Id" class="btn btn-sm btn-danger">Delete</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>