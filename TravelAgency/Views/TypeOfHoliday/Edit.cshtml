@model TravelAgency.Models.Trip
@using TravelAgency.Models
@using Microsoft.AspNetCore.Mvc.Rendering

<h1>Edit Trip</h1>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Country"></label>
        <input asp-for="Country" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="City"></label>
        <input asp-for="City" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="HotelName"></label>
        <input asp-for="HotelName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="HotelAddress"></label>
        <input asp-for="HotelAddress" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Type Of Holiday</label>
        <select asp-for="typeofHoldayId"
                class="form-control"
                asp-items="@(new SelectList(ViewBag.TypeOfHolidays, "Id", "Name"))">
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="NumberOfNights"></label>
        <input asp-for="NumberOfNights" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Price"></label>
        <input asp-for="Price" type="number" step="0.01" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Quantity"></label>
        <input asp-for="Quantity" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="date"></label>
        <input asp-for="date" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="status"></label>
        <select asp-for="status"
                class="form-control"
                asp-items="Html.GetEnumSelectList<StatusTrip>()">
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
