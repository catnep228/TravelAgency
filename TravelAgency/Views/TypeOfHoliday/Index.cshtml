@model List<TravelAgency.Models.TypeOfHoliday>

<h1>Type Of Holidays</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Type</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Type Activity</th>
            <th>Trips Count</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var th in Model)
        {
            <tr>
                <td>@th.Name</td>
                <td>@th.TypeOfACt</td>
                <td>@th.Trips?.Count() ?? 0</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@th.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Details" asp-route-id="@th.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@th.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
