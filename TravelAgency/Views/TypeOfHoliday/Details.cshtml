@model TravelAgency.Models.Trip

<hr />
<div class="row">
    <div class="col-md-6">
        <h4>Included Services</h4>
        <ul class="list-group">
            @if (Model.Services != null && Model.Services.Any())
            {
                @foreach (var service in Model.Services)
                {
                    <li class="list-group-list-item">@service.Name - @service.Price.ToString("C")</li>
                }
            }
            else
            {
                <li class="list-group-item text-muted">No included services</li>
            }
        </ul>
    </div>
    <div class="col-md-6">
        <h4>Additional Services</h4>
        <ul class="list-group">
            @if (Model.AdditionalServices != null && Model.AdditionalServices.Any())
            {
                @foreach (var service in Model.AdditionalServices)
                {
                    <li class="list-group-item">@service.Name (+@service.Price.ToString("C"))</li>
                }
            }
            else
            {
                <li class="list-group-item text-muted">No additional services available</li>
            }
        </ul>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>