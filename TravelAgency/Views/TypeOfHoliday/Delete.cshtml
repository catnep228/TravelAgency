@model TravelAgency.Models.TypeOfHoliday

<h1>Delete Type Of Holiday</h1>

<p>Are you sure you want to delete this Type Of Holiday?</p>

<div>
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Type Activity:</strong> @Model.TypeOfACt</p>
    <p><strong>Trips Count:</strong> @Model.Trips?.Count() ?? 0</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
