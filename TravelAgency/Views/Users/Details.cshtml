@model TravelAgency.Models.User

@{
    ViewData["Title"] = "User Details";
}

<h1>User Details</h1>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Account Information</h5>
        <hr />
        <dl class="row">
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Phone Number</dt>
            <dd class="col-sm-8">@Model.PhoneNumber</dd>

            <dt class="col-sm-4">Role</dt>
            <dd class="col-sm-8">@(Model.Role?.Name ?? "No Role")</dd>
        </dl>

        <h5 class="card-title mt-4">Passenger Profile</h5>
        <hr />
        @if (Model.Passanger != null)
        {
            <dl class="row">
                <dt class="col-sm-4">Full Name</dt>
                <dd class="col-sm-8">@Model.Passanger.LastName @Model.Passanger.FirstName @Model.Passanger.MiddleName</dd>

                <dt class="col-sm-4">Passport</dt>
                <dd class="col-sm-8">@Model.Passanger.Passport</dd>

                <dt class="col-sm-4">International Passport</dt>
                <dd class="col-sm-8">@Model.Passanger.InternationalPassport</dd>

                <dt class="col-sm-4">Insurance Policy</dt>
                <dd class="col-sm-8">@Model.Passanger.Policy</dd>

                <dt class="col-sm-4">Birth Certificate</dt>
                <dd class="col-sm-8">@(Model.Passanger.BirthCertificate ? "Yes" : "No")</dd>
            </dl>
        }
        else
        {
            <p class="text-muted">No passenger information associated with this user.</p>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>