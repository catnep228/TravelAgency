@model List<TravelAgency.Models.User>

<h1>Users</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New User</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Email</th>
            <th>Phone</th>
            <th>Role</th>
            <th>Passanger</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.PhoneNumber</td>
                <td>@user.Role?.Name</td>
                <td>@user.Passanger?.FirstName</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
