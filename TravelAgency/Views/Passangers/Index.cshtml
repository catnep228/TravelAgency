@model List<TravelAgency.Models.Passanger>

<h1>Passangers</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Passanger</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Middle Name</th>
            <th>Birth Certificate</th>
            <th>Passport</th>
            <th>International Passport</th>
            <th>Policy</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.FirstName</td>
                <td>@p.LastName</td>
                <td>@p.MiddleName</td>
                <td>@(p.BirthCertificate == true ? "Yes" : "No")</td>
                <td>@p.Passport</td>
                <td>@p.InternationalPassport</td>
                <td>@p.Policy</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
