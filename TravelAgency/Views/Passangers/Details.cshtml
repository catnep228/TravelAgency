@model TravelAgency.Models.Passanger

<h1>Passanger Details</h1>

<div>
    <p><strong>First Name:</strong> @Model.FirstName</p>
    <p><strong>Last Name:</strong> @Model.LastName</p>
    <p><strong>Middle Name:</strong> @Model.MiddleName</p>
    <p><strong>Birth Certificate:</strong> @(Model.BirthCertificate == true ? "Yes" : "No")</p>
    <p><strong>Passport:</strong> @Model.Passport</p>
    <p><strong>International Passport:</strong> @Model.InternationalPassport</p>
    <p><strong>Policy:</strong> @Model.Policy</p>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
