@model TravelAgency.Models.Passanger

<h1>Edit Passanger</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>First Name</label>
        <input asp-for="FirstName" class="form-control" required />
    </div>
    <div class="mb-3">
        <label>Last Name</label>
        <input asp-for="LastName" class="form-control" required />
    </div>
    <div class="mb-3">
        <label>Middle Name</label>
        <input asp-for="MiddleName" class="form-control" />
    </div>
    <div class="form-check mb-3">
        <input asp-for="BirthCertificate" class="form-check-input" type="checkbox" />
        <label class="form-check-label">Birth Certificate</label>
    </div>
    <div class="mb-3">
        <label>Passport</label>
        <input asp-for="Passport" class="form-control" />
    </div>
    <div class="mb-3">
        <label>International Passport</label>
        <input asp-for="InternationalPassport" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Policy</label>
        <input asp-for="Policy" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
