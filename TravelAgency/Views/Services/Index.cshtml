@model List<TravelAgency.Models.Service>

<h1>Services</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Service</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Type Service</th>
            <th>Price</th>
            <th class="text-center">Trips Count</th>
            <th class="text-center">Add. Trips Count</th>
            <th class="text-center">Orders Count</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Name</td>
                <td>@s.TypeService</td>
                <td>@s.Price.ToString("N2") ₽</td>
                <td class="text-center">@(s.Trips?.Count ?? 0)</td>
                <td class="text-center">@(s.TripsAdditional?.Count ?? 0)</td>
                <td class="text-center">@(s.Orders?.Count ?? 0)</td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-sm btn-danger">Delete</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>