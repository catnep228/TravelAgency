@model TravelAgency.Models.Service

<h1>Service Details</h1>

<div>
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Type Service:</strong> @Model.TypeService</p>
    <p><strong>Trips Count:</strong> @Model.Trips?.Count() ?? 0</p>
    <p><strong>Additional Trips Count:</strong> @Model.TripsAdditional?.Count() ?? 0</p>
    <p><strong>Orders Count:</strong> @Model.Orders?.Count() ?? 0</p>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
